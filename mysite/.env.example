# Copy to .env locally, or set these as environment variables on PythonAnywhere.
# .env is gitignored and is NOT deployed with git pull.

SECRET_KEY=your-django-secret-key

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=adeaef001@smtp-brevo.com
EMAIL_HOST_PASSWORD=your-brevo-smtp-key
DEFAULT_FROM_EMAIL=Dream Analytica <r@dreamanalytica.com>

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Cloudflare Turnstile — create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# Add dreamanalytica.com (and localhost for dev) as allowed hostnames.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
